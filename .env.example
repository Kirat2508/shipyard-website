# Copy to Vercel → Project → Settings → Environment Variables, then redeploy.
#
# Admin password (/admin-applications sign-in):
#   APPLY_ADMIN_PASSWORD = the exact password you type on the login screen (pick a strong value).
#   APPLY_ADMIN_SECRET = long random string (32+ chars) used only to sign the session cookie —
#     it is NOT your login password. Generate e.g. openssl rand -hex 32
# If login always fails: typo in vars, or env not applied until you redeploy (Production vs Preview).
#
# Supabase (run supabase/migrations/001_shipyard_applications.sql in SQL editor first)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Admin dashboard (bookmark; not linked from the public site):
#   https://YOUR_DOMAIN/admin-applications
APPLY_ADMIN_PASSWORD=change_me_strong_password
APPLY_ADMIN_SECRET=change_me_random_32chars_minimum
